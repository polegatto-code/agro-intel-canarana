### Variáveis de Ambiente para AgroIntel Canarana

# Este arquivo contém as variáveis de ambiente necessárias para rodar o projeto.
# Copie este arquivo para `.env` e preencha com suas credenciais e configurações.

# ============================================================================
# DATABASE
# ============================================================================
# Conexão com o banco de dados MySQL. Se estiver usando docker-compose, o host é 'db'.
DATABASE_URL="mysql://agro_user:agro_password@db:3306/agro_intel"
DB_ROOT_PASSWORD="root"
DB_NAME="agro_intel"
DB_USER="agro_user"
DB_PASSWORD="agro_password"

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Chave secreta para JWT. MUDE ISSO EM PRODUÇÃO!
JWT_SECRET="seu-secret-muito-seguro-aqui"

# Credenciais Manus OAuth (se aplicável)
VITE_APP_ID="seu-manus-app-id"
OAUTH_SERVER_URL="https://api.manus.im"
VITE_OAUTH_PORTAL_URL="https://portal.manus.im"
OWNER_OPEN_ID="seu-open-id"
OWNER_NAME="José Carvalho"

# ============================================================================
# TELEGRAM
# ============================================================================
# Token do bot Telegram e ID do chat para notificações.
TELEGRAM_BOT_TOKEN="seu-token-bot-telegram"
TELEGRAM_CHAT_ID="seu-chat-id-telegram"

# ============================================================================
# OPENWEATHERMAP
# ============================================================================
# Chave da API do OpenWeatherMap para dados climáticos reais.
OPENWEATHER_API_KEY="sua-api-key-openweather"

# ============================================================================
# MANUS APIs (Built-in Forge)
# ============================================================================
# Chaves e URLs para APIs internas do Manus (se aplicável).
BUILT_IN_FORGE_API_KEY="sua-api-key-manus"
BUILT_IN_FORGE_API_URL="https://api.manus.im"
VITE_FRONTEND_FORGE_API_URL="https://api.manus.im"
VITE_FRONTEND_FORGE_API_KEY="sua-api-key-manus-frontend"

# ============================================================================
# APPLICATION
# ============================================================================
# Ambiente de execução (development ou production).
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="info"

# ============================================================================
# ANALYTICS
# ============================================================================
# Configurações para o serviço de analytics (se aplicável).
VITE_ANALYTICS_ENDPOINT="https://analytics.example.com"
VITE_ANALYTICS_WEBSITE_ID="seu-id-analytics"
